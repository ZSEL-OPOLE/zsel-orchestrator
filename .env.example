# ZSEL Orchestrator — zmienne środowiskowe
# Skopiuj do .env i uzupełnij

# Ollama (na klastrze przez VPN lub lokalnie)
ORCH_OLLAMA_BASE_URL=http://10.189.3.11:11434
ORCH_OLLAMA_THINK_MODEL=qwen3.5:27b
ORCH_OLLAMA_FAST_MODEL=qwen3.5:9b
ORCH_OLLAMA_EMBED_MODEL=nomic-embed-text

# Qdrant (lokalny docker compose lub klaster)
ORCH_QDRANT_HOST=localhost
ORCH_QDRANT_PORT=6333

# PostgreSQL (opcjonalnie — do persystencji zadań)
ORCH_DATABASE_URL=postgresql+asyncpg://orch:orch@localhost:5432/orchestrator

# Redis (opcjonalnie — rate limiting, cache)
ORCH_REDIS_URL=redis://localhost:6379/0

# Tryb pracy
ORCH_LOCAL_MODE=true        # true = in-process, false = via API
ORCH_LOG_LEVEL=INFO
ORCH_LEARNING_ENABLED=true
ORCH_WORKSPACE_ROOT=/Users/lkolo-prez/Documents/LKP/01_ZSEL/SERVERS-CLEAN
